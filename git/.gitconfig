[user]
	name = Simon Egersand
	email = segersand@spotify.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIIO3Gjajrz116sS9rqrtO/zPwTsQgSoginxXIasZepXS
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
; To enable signed commits (verified badge on GitHub):
;   1. Open 1Password → Settings → Developer → "Use the SSH agent"
;   2. Verify with: ssh-add -L (should list your ed25519 key)
;   3. Flip gpgsign below to true (and add it under [tag] too)
[commit]
	gpgsign = false
[core]
	excludesfile = ~/.gitignore
	editor = nvim
	pager = delta
	fsmonitor = true
	untrackedCache = true
[interactive]
	diffFilter = delta --color-only

; Make delta look like diff-so-fancy
[delta]
  features = "diff-so-fancy"
  line-numbers = true
  syntax-theme = "Monokai Extended"
  side-by-side = false
  navigate = true
  decorations = always
  zero-style = syntax
  minus-emph-style = bold red
  plus-emph-style = bold green
  hunk-header-decoration-style = underline purple

[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
	algorithm = histogram
[push]
	autoSetupRemote = true
[fetch]
	prune = true
	pruneTags = true
[pull]
	rebase = true
[rebase]
	autoStash = true
	autoSquash = true
[rerere]
	enabled = true
	autoUpdate = true
[branch]
	sort = -committerdate
[column]
	ui = auto
[help]
	autocorrect = prompt
[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
[url "ssh://git@ghe.spotify.net/"]
	insteadOf = https://ghe.spotify.net/
[init]
	defaultBranch = main
[alias]
	x = !git-x
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[lfs]
	locksverify = false
[maintenance]
	repo = /Users/segersand/repos/services-pilot
