#!/usr/bin/env bash
# File contents (bat) + git blame, in one view. Optional line range.
# Usage:
#   file-context path/to/file
#   file-context path/to/file 50:80

set -e
file="${1:?usage: file-context <path> [start:end]}"
range="${2:-}"

if [[ -n "$range" ]]; then
  bat --style=numbers,header --color=always --line-range "$range" "$file"
else
  bat --style=numbers,header --color=always "$file"
fi

# Run every git command from the file's directory — blame from $PWD fails
# when the file lives in a different repo (or a different subdir of one)
dir=$(dirname "$file")
base=$(basename "$file")
if git -C "$dir" rev-parse --git-dir >/dev/null 2>&1; then
  printf '\n=== BLAME (author, date, sha per line) ===\n'
  if [[ -n "$range" ]]; then
    git -C "$dir" blame --date=short -e -L "${range/:/,}" -- "$base"
  else
    git -C "$dir" blame --date=short -e -- "$base"
  fi
fi
